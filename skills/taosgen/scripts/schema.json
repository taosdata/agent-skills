{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taosdata.com/taosgen-config-schema.json",
  "title": "Taosgen Configuration Schema",
  "description": "Strict schema for taosgen YAML configuration files based on official documentation",
  "type": "object",
  "definitions": {
    "tdengineConfig": {
      "type": "object",
      "description": "TDengine connection configuration",
      "properties": {
        "dsn": {
          "type": "string",
          "description": "Connection string, e.g., taos+ws://root:taosdata@localhost:6041/tsbench",
          "pattern": "^taos\\+ws?://[^:]+:[^@]+@[^:]+:\\d+/\\w+$"
        },
        "drop_if_exists": {
          "type": "boolean",
          "description": "Whether to drop existing database",
          "default": false
        },
        "props": {
          "type": "string",
          "description": "Database properties, e.g., precision 'ms' vgroups 4"
        },
        "pool": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "max_size": { "type": "integer", "default": 100 },
            "min_size": { "type": "integer", "default": 2 },
            "timeout": { "type": "integer", "default": 1000 }
          }
        }
      },
      "required": ["dsn"],
      "additionalProperties": false
    },
    "mqttConfig": {
      "type": "object",
      "description": "MQTT broker configuration - ONLY these parameters are supported",
      "properties": {
        "uri": {
          "type": "string",
          "description": "MQTT Broker URI",
          "default": "tcp://localhost:1883"
        },
        "user": {
          "type": "string",
          "description": "Login username"
        },
        "password": {
          "type": "string",
          "description": "Login password"
        },
        "client_id": {
          "type": "string",
          "description": "Client ID prefix",
          "default": "taosgen"
        },
        "keep_alive": {
          "type": "integer",
          "description": "Keep alive interval in seconds",
          "default": 5
        },
        "clean_session": {
          "type": "boolean",
          "description": "Whether to clean session state",
          "default": true
        },
        "max_buffered_messages": {
          "type": "integer",
          "description": "Maximum buffered messages",
          "default": 10000
        }
      },
      "additionalProperties": false
    },
    "kafkaConfig": {
      "type": "object",
      "description": "Kafka broker configuration",
      "properties": {
        "bootstrap_servers": {
          "type": "string",
          "description": "Kafka cluster addresses, e.g., host1:9092,host2:9092",
          "default": "localhost:9092"
        },
        "client_id": {
          "type": "string",
          "description": "Client ID prefix",
          "default": "taosgen"
        },
        "topic": {
          "type": "string",
          "description": "Topic name"
        },
        "rdkafka_options": {
          "type": "object",
          "description": "Additional librdkafka options",
          "properties": {
            "security.protocol": {
              "type": "string",
              "enum": ["plaintext", "ssl", "sasl_plaintext", "sasl_ssl"]
            },
            "sasl.mechanism": {
              "type": "string",
              "enum": ["PLAIN", "SCRAM-SHA-256", "SCRAM-SHA-512", "GSSAPI"]
            },
            "sasl.username": { "type": "string" },
            "sasl.password": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "columnConfig": {
      "type": "object",
      "description": "Column definition - gen_type is INFERRED from presence of keys",
      "properties": {
        "name": {
          "type": "string",
          "description": "Column name"
        },
        "type": {
          "type": "string",
          "description": "Data type",
          "enum": [
            "timestamp", "bool",
            "tinyint", "tinyint unsigned", "smallint", "smallint unsigned",
            "int", "int unsigned", "bigint", "bigint unsigned",
            "float", "double", "decimal",
            "nchar", "varchar", "binary"
          ]
        },
        "count": {
          "type": "integer",
          "description": "Number of columns to generate with this name as prefix (e.g., count=3 -> col1, col2, col3)",
          "default": 1,
          "minimum": 1
        },
        "min": {
          "type": ["number", "integer"],
          "description": "Minimum value (for random/order generation)"
        },
        "max": {
          "type": ["number", "integer"],
          "description": "Maximum value (for random/order generation)"
        },
        "values": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of values to randomly select from"
        },
        "expr": {
          "type": "string",
          "description": "Lua expression for expression generation"
        },
        "start": {
          "type": ["string", "integer"],
          "description": "Start value for timestamp, e.g., 'now', 'now + 10s', or 1700000000000"
        },
        "precision": {
          "type": "string",
          "enum": ["s", "ms", "us", "ns"],
          "description": "Timestamp precision"
        },
        "step": {
          "type": ["integer", "string"],
          "description": "Step size for timestamp, e.g., 1 or '300s'"
        }
      },
      "required": ["name", "type"],
      "additionalProperties": false
    },
    "generationConfig": {
      "type": "object",
      "description": "Data generation control",
      "properties": {
        "interlace": {
          "type": "integer",
          "description": "Interlace rows count",
          "default": 0,
          "minimum": 0
        },
        "concurrency": {
          "type": "integer",
          "description": "Data generation thread count (for MQTT/Kafka)",
          "minimum": 1
        },
        "rows_per_table": {
          "type": "integer",
          "description": "Rows per table (-1 for unlimited)",
          "default": 10000
        },
        "rows_per_batch": {
          "type": "integer",
          "description": "Rows per batch request",
          "default": 10000,
          "minimum": 1
        },
        "num_cached_batches": {
          "type": "integer",
          "description": "Cached batches (0 = disabled)",
          "default": 0,
          "minimum": 0
        },
        "tables_reuse_data": {
          "type": "boolean",
          "description": "Reuse data across tables",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "stepConfig": {
      "type": "object",
      "description": "Job step configuration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Step display name"
        },
        "uses": {
          "type": "string",
          "description": "Action to use",
          "enum": [
            "tdengine/create-database",
            "tdengine/create-super-table",
            "tdengine/create-child-table",
            "tdengine/insert",
            "mqtt/publish",
            "kafka/produce"
          ]
        },
        "with": {
          "type": "object",
          "description": "Action parameters"
        }
      },
      "required": ["uses"],
      "additionalProperties": false
    },
    "jobConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Job display name"
        },
        "needs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dependencies (job keys)"
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/stepConfig" },
          "minItems": 1
        }
      },
      "required": ["steps"],
      "additionalProperties": false
    }
  },
  "properties": {
    "tdengine": {
      "$ref": "#/definitions/tdengineConfig"
    },
    "mqtt": {
      "$ref": "#/definitions/mqttConfig"
    },
    "kafka": {
      "$ref": "#/definitions/kafkaConfig"
    },
    "schema": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Schema name (table name)"
        },
        "tbname": {
          "type": "object",
          "properties": {
            "prefix": { "type": "string", "default": "d" },
            "count": { "type": "integer", "default": 10000 },
            "from": { "type": "integer", "default": 0 }
          }
        },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/definitions/columnConfig" }
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/definitions/columnConfig" }
        },
        "generation": {
          "$ref": "#/definitions/generationConfig"
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "jobs": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "$ref": "#/definitions/jobConfig"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["schema", "jobs"],
  "additionalProperties": false
}
